---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/DistCol.png" />
    <meta name="viewport" content="width=device-width" />
    <title>404 - Page Not Found | Isaac Oliva-González</title>
  </head>
  <body class="bg-gradient-to-br from-stone-50 to-stone-100 min-h-screen flex items-center justify-center">
    <div class="text-center px-4">
      <div class="mb-8">
        <h1 class="text-6xl font-bold text-stone-800 mb-4">404</h1>
        <h2 class="text-2xl font-semibold text-stone-700 mb-4">Page Not Found</h2>
        <p class="text-stone-600 mb-8 max-w-md mx-auto">
          This page is not part of the optimal solution set. Try exploring feasible alternatives.
        </p>
      </div>
      
      <div class="space-y-4">
        <a href="/" class="inline-block bg-stone-700 text-white px-8 py-3 rounded-full hover:bg-stone-800 transition font-medium shadow-md hover:shadow-lg">
          Return to Home
        </a>
      </div>
      
      <!-- Solution space exploration animation -->
      <div class="mt-12 flex justify-center gap-2">
        <div class="w-3 h-3 bg-stone-300 rounded-full animate-explore-1"></div>
        <div class="w-3 h-3 bg-stone-400 rounded-full animate-explore-2"></div>
        <div class="w-3 h-3 bg-stone-500 rounded-full animate-explore-3"></div>
        <div class="w-3 h-3 bg-stone-600 rounded-full animate-explore-4"></div>
        <div class="w-3 h-3 bg-stone-700 rounded-full animate-explore-5"></div>
      </div>
      
      <p class="text-xs text-stone-500 mt-4">Exploring solution space...</p>
    </div>
    
    <style>
      @keyframes explore {
        0%, 100% { 
          transform: scale(1) translateY(0);
          opacity: 0.4;
        }
        50% { 
          transform: scale(1.3) translateY(-8px);
          opacity: 1;
        }
      }
      
      .animate-explore-1 { animation: explore 2s ease-in-out infinite; }
      .animate-explore-2 { animation: explore 2s ease-in-out 0.2s infinite; }
      .animate-explore-3 { animation: explore 2s ease-in-out 0.4s infinite; }
      .animate-explore-4 { animation: explore 2s ease-in-out 0.6s infinite; }
      .animate-explore-5 { animation: explore 2s ease-in-out 0.8s infinite; }
    </style>
  </body>
</html>