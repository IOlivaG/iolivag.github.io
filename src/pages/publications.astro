---

        <html lang="en">
        <head>
            <meta charset="utf-8" />
            <link rel="icon" type="image/png" href="/Research.png" />
            <meta name="viewport" content="width=device-width" />
            <title>Publications - Isaac Oliva-González</title>
        </head>
        <body class="bg-stone-100 text-stone-900 min-h-screen">
            <main class="max-w-4xl mx-auto px-6 py-12 lg:py-16">
        <div class="sticky top-0 bg-stone-100 z-10 pb-4 mb-10">
        <a href="/" class="text-sm text-stone-600 hover:text-stone-900 underline">← Back to home</a>
        
        <h1 class="text-3xl font-bold mt-4">All Publications</h1>
        
        <nav class="flex gap-4 text-base mt-6" role="tablist">
            <a class="text-stone-600 hover:text-stone-900 transition hover:underline underline-offset-4" href="#preprints" role="tab">Preprints</a>
            <a class="text-stone-600 hover:text-stone-900 transition hover:underline underline-offset-4" href="#proceedings" role="tab">Proceedings</a>
            <a class="text-stone-600 hover:text-stone-900 transition hover:underline underline-offset-4" href="#presentations" role="tab">Presentations</a>
        </nav>
        </div>

      <!-- Preprints & Manuscripts in Progress -->
      <section id="preprints" class="mb-6 scroll-mt-40">
        <h2 class="text-2xl font-bold mb-6 text-stone-800">Preprints & Manuscripts in Progress</h2>
        <div class="space-y-3">
          {publications.preprints.map((pub, idx) => (
            <article class="p-3 rounded-xl border border-stone-200 bg-white/70">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="flex items-baseline gap-2">
                    <span class="text-xs font-bold text-stone-500">[S{idx + 1}]</span>
                    <h3 class="text-lg font-semibold leading-snug">
                      {pub.links.paper ? (
                        <a class="hover:text-stone-700 underline" href={pub.links.paper} target="_blank" rel="noreferrer">{pub.title}</a>
                      ) : (
                        <span>{pub.title}</span>
                      )}
                    </h3>
                  </div>
                  <p class="text-sm text-stone-600 mt-2">
                    {pub.authors.map((author, idx) => (
                      <>
                        {author === cvData.shortName || author.startsWith("I. Oliva") ? <strong>{author}</strong> : author}
                        {idx < pub.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>
                  <p class="text-sm text-stone-500 mt-2">
                    <em>{pub.journal}</em>
                    {pub.publisher && `, ${pub.publisher}`}
                    {pub.status && ` (${pub.status})`},
                    {pub.year}
                    {pub.doi && (
                      <>
                        . DOI: <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noreferrer" class="underline hover:text-stone-900">{pub.doi}</a>
                      </>
                    )}
                  </p>
                  {pub.preprint && (
                    <p class="text-sm text-stone-500 mt-2">
                      <a href={pub.links.paper} target="_blank" rel="noreferrer" class="underline hover:text-stone-900">Preprint available</a>
                    </p>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Conference Proceedings -->
      <section id="proceedings" class="mb-6 scroll-mt-40">
        <h2 class="text-2xl font-bold mb-6 text-stone-800">Conference Proceedings</h2>
        <div class="space-y-3">
          {publications.proceedings.map((pub, idx) => (
            <article class="p-3 rounded-xl border border-stone-200 bg-white/70">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="flex items-baseline gap-2">
                    <span class="text-xs font-bold text-stone-500">[C{idx + 1}]</span>
                    <h3 class="text-lg font-semibold leading-snug">
                      {pub.links.paper ? (
                        <a class="hover:text-stone-700 underline" href={pub.links.paper} target="_blank" rel="noreferrer">{pub.title}</a>
                      ) : (
                        <span>{pub.title}</span>
                      )}
                    </h3>
                  </div>
                  <p class="text-sm text-stone-600 mt-2">
                    {pub.authors.map((author, idx) => (
                      <>
                        {author === cvData.shortName || author.startsWith("I. Oliva") ? <strong>{author}</strong> : author}
                        {idx < pub.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>
                  <p class="text-sm text-stone-500 mt-2">
                    <em>{pub.journal}</em>
                    {pub.publisher && `, ${pub.publisher}`}
                    {pub.volume && `, vol. ${pub.volume}`}
                    {pub.issue && `, no. ${pub.issue}`}
                    {pub.pages && `, pp. ${pub.pages}`}
                    {pub.year && `, ${pub.year}`}
                    {pub.issn && `. ISSN ${pub.issn}`}
                    {pub.doi && (
                      <>
                        . DOI: <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noreferrer" class="underline hover:text-stone-900">{pub.doi}</a>
                      </>
                    )}
                  </p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Conference Presentations -->
      <section id="presentations" class="mb-6 scroll-mt-40">
        <h2 class="text-2xl font-bold mb-6 text-stone-800">Conference Presentations</h2>
        <div class="space-y-3">
          {publications.presentations.map((pub, idx) => (
            <article class="p-3 rounded-xl border border-stone-200 bg-white/70">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="flex items-baseline gap-2">
                    <span class="text-xs font-bold text-stone-500">[P{idx + 1}]</span>
                    <h3 class="text-lg font-semibold leading-snug">{pub.title}</h3>
                  </div>
                  <p class="text-sm text-stone-600 mt-2">
                    {pub.authors.map((author, idx) => (
                      <>
                        {author === cvData.shortName || author.startsWith("I. Oliva") ? <strong>{author}</strong> : author}
                        {idx < pub.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>
                  <p class="text-sm text-stone-500 mt-2">
                    <em>{pub.conference}</em>, {pub.location}, {pub.year}
                  </p>
                  <p class="text-xs text-stone-400 mt-1 italic">
                    {pub.type}
                  </p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
        <div class=" mb-8 pt-1 border-stone-200 text-left">
            <a href="/" class="text-sm text-stone-600 hover:text-stone-900 underline">← Back to home</a>
        </div>
        <footer class="pt-6 text-center text-sm text-stone-500">Last updated in March 2026</footer>    
    </main>
  </body>
</html>