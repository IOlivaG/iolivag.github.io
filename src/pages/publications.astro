---

<BaseLayout 
  title="Journal Articles - Isaac Oliva-González" 
  description="Complete list of academic publications, preprints, conference proceedings, and presentations on quantum computing and optimization research."
>
  <div class="bg-stone-100 text-stone-900 min-h-screen">
            <main class="max-w-4xl mx-auto px-6 py-12 lg:py-16">
        <div class="sticky top-0 bg-stone-100 z-10 pb-4 mb-10">
        <a href="/" class="text-sm text-stone-600 hover:text-stone-900 underline">← Back to home</a>
        
        <h1 class="text-3xl font-bold mt-4">All Publications</h1>
        
        <nav class="flex gap-4 text-base mt-2" role="tablist">
          <a class="text-stone-600 hover:text-stone-900 transition hover:underline underline-offset-4" href="#journal" role="tab">Journal Articles</a>
          <a class="text-stone-600 hover:text-stone-900 transition hover:underline underline-offset-4" href="#book" role="tab">Book Chapters</a>
          <a class="text-stone-600 hover:text-stone-900 transition hover:underline underline-offset-4" href="#conference" role="tab">Conference Proceedings & Presentations</a>
        </nav>
        </div>

      <!--  Journal Articles -->
      <section id="journal" class="mb-8 scroll-mt-40">
        <h2 class="text-2xl font-bold mb-3 text-stone-800">Journal Articles</h2>
        <div class="space-y-3">
          {publications.journal.map((pub, idx) => (
            <article class="p-3 rounded-xl border border-stone-200 bg-white/70">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="flex items-baseline gap-2">
                    <span class="text-xs font-bold text-stone-500">[J{idx + 1}]</span>
                    <h3 class="text-[17px] font-semibold leading-snug">
                      {pub.links.paper ? (
                        <a class="hover:text-stone-700 underline" href={pub.links.paper} target="_blank" rel="noreferrer">{pub.title}</a>
                      ) : (
                        <span>{pub.title}</span>
                      )}
                    </h3>
                  </div>
                  <p class="text-sm text-stone-600 mt-2">
                    {pub.authors.map((author, idx) => (
                      <>
                        {author === cvData.shortName || author.startsWith("I. Oliva") ? <strong>{author}</strong> : author}
                        {idx < pub.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>
                  <p class="text-sm text-stone-500 mt-2">
                    <span>
                      <em>{pub.journal}</em>{pub.year && `, ${pub.year}`}{pub.status && ` (${pub.status})`}
                      {pub.doi && (
                        <>
                          {" | "}
                          <a
                    href={`https://doi.org/${pub.doi}`}
                    target="_blank"
                    rel="noreferrer"
                    class="underline hover:text-stone-900"
                  >
                    DOI: {pub.doi}
                  </a>
                        </>
                      )}
                    </span>
                  </p>
                      {pub.preprint && pub.preprintLink && (
                    <p class="text-xs text-stone-500 mt-2">
                      <a
                        href={pub.preprintLink}
                        target="_blank"
                        rel="noreferrer"
                        class="underline hover:text-stone-900"
                      >
                        Preprint available
                      </a>
                    </p>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!--  Book Chapters -->
      <section id="book" class="mb-8 scroll-mt-40">
        <h2 class="text-2xl font-bold mb-3 text-stone-800">Book Chapters</h2>
        <div class="space-y-3">
          {publications.book.map((pub, idx) => (
            <article class="p-3 rounded-xl border border-stone-200 bg-white/70">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="flex items-baseline gap-2">
                    <span class="text-xs font-bold text-stone-500">[B{idx + 1}]</span>
                    <h3 class="text-[17px] font-semibold leading-snug">
                      {pub.links.paper ? (
                        <a class="hover:text-stone-700 underline" href={pub.links.paper} target="_blank" rel="noreferrer">{pub.title}</a>
                      ) : (
                        <span>{pub.title}</span>
                      )}
                    </h3>
                  </div>
                  <p class="text-sm text-stone-600 mt-2">
                    {pub.authors.map((author, idx) => (
                      <>
                        {author === cvData.shortName || author.startsWith("I. Oliva") ? <strong>{author}</strong> : author}
                        {idx < pub.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>
                  <p class="text-sm text-stone-500 mt-2">
                    <span>
                      <em>{pub.journal}</em>{pub.publisher && `, ${pub.publisher}`}{pub.year && `, ${pub.year}`}{pub.status && ` (${pub.status})`}
                    </span>
                  </p>

                  {pub.doi && (
                    <p class="text-xs text-stone-500 mt-1">
                      DOI:{" "}
                      <a
                        href={`https://doi.org/${pub.doi}`}
                        target="_blank"
                        rel="noreferrer"
                        class="underline hover:text-stone-900"
                      >
                        {pub.doi}
                      </a>
                    </p>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

    
      <!-- Conference Proceedings & Presentations -->
      <section id="conference" class="mb-6 scroll-mt-40">
        <h2 class="text-2xl font-bold mb-3 text-stone-800">Conference Proceedings & Presentations</h2>

        <!-- Proceedings -->
        <h3 class="text-xl font-semibold mb-2 text-stone-700">Proceedings</h3>
        <div class="space-y-3 mb-4">
          {publications.proceedings.map((pub, idx) => (
            <article class="p-3 rounded-xl border border-stone-200 bg-white/70">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="flex items-baseline gap-2">
                    <span class="text-xs font-bold text-stone-500">[C{idx + 1}]</span>
                    <h3 class="text-[17px] font-semibold leading-snug">
                      {pub.links.paper ? (
                        <a class="hover:text-stone-700 underline" href={pub.links.paper} target="_blank" rel="noreferrer">{pub.title}</a>
                      ) : (
                        <span>{pub.title}</span>
                      )}
                    </h3>
                  </div>

                  <p class="text-sm text-stone-600 mt-2">
                    {pub.authors.map((author, idx) => (
                      <>
                        {author === cvData.shortName || author.startsWith("I. Oliva") ? <strong>{author}</strong> : author}
                        {idx < pub.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>

                  <p class="text-sm text-stone-500 mt-2">
                    <span><em>{pub.journal}</em>{pub.year && `, ${pub.year}`}</span>
                  </p>

                  {pub.doi && (
                    <p class="text-xs text-stone-500 mt-2">
                      DOI:{" "}
                      <a
                        href={`https://doi.org/${pub.doi}`}
                        target="_blank"
                        rel="noreferrer"
                        class="underline hover:text-stone-900"
                      >
                        {pub.doi}
                      </a>
                    </p>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- Presentations -->
        <h3 class="text-xl font-semibold mb-2 text-stone-700">Presentations</h3>
        <div class="space-y-3">
          {publications.presentations.map((pub, idx) => (
            <article class="p-3 rounded-xl border border-stone-200 bg-white/70">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="flex items-baseline gap-2">
                    <span class="text-xs font-bold text-stone-500">[P{idx + 1}]</span>
                    <h3 class="text-[17px] font-semibold leading-snug">{pub.title}</h3>
                  </div>

                  <p class="text-sm text-stone-600 mt-2">
                    {pub.authors.map((author, idx) => (
                      <>
                        {author === cvData.shortName || author.startsWith("I. Oliva") ? <strong>{author}</strong> : author}
                        {idx < pub.authors.length - 1 ? ', ' : ''}
                      </>
                    ))}
                  </p>

                  <p class="text-sm text-stone-500 mt-2">
                    <em>{pub.conference}</em>, {pub.location}, {pub.year}
                  </p>

                  <p class="text-xs text-stone-500 mt-2 italic">
                    {pub.type}
                  </p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      
        <div class=" mb-8 pt-1 border-stone-200 text-left">
            <a href="/" class="text-sm text-stone-600 hover:text-stone-900 underline">← Back to home</a>
        </div>
        <footer class="pt-6 text-center text-sm text-stone-500">Last updated in May 2026</footer>    
    </main>
  </body>
</html>div>
</BaseLayout