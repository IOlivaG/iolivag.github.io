---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Isaac Oliva-González', description = 'MSc Computer Science researcher specializing in quantum computing and optimization algorithms. Explore my research, publications, and projects.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/bit-cuantico.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Isaac Oliva-González" />
    <meta name="keywords" content="quantum computing, optimization, research, computer science" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://iolivag.github.io/bit-cuantico.png" />
    <meta property="og:url" content="https://iolivag.github.io" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family: system-ui, sans-serif;
    color-scheme: light;
  }
</style>
